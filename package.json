{
  "name": "expo-ai-core",
  "version": "1.0.1",
  "description": "Production-grade AI SDK for Expo apps with chat, streaming, tools, voice, memory, plugins, and agents.",
  "author": "Arhan Ansari (https://github.com/ArhanAnsari)",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArhanAnsari/expo-ai-core.git"
  },
  "bugs": {
    "url": "https://github.com/ArhanAnsari/expo-ai-core/issues"
  },
  "homepage": "https://github.com/ArhanAnsari/expo-ai-core#readme",
  "keywords": [
    "expo",
    "react-native",
    "ai",
    "chatgpt",
    "openai",
    "gemini",
    "expo-ai",
    "ai-sdk"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "expo-speech": ">=13.0.0",
    "expo-av": ">=15.0.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "expo-clipboard": ">=6.0.0",
    "expo-haptics": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "expo-av": {
      "optional": true
    },
    "expo-speech": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "expo-clipboard": {
      "optional": true
    },
    "expo-haptics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.18",
    "@types/react-native": "^0.73.0",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "jsdom": "^26.0.0",
    "expo-av": "~15.0.0",
    "expo-clipboard": "~6.0.3",
    "expo-haptics": "~14.0.1",
    "expo-speech": "~13.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
